{
  "name": "packyapi-balance-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop monitor for PackyAPI wallet balance.",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wu81313-lab/githubTest.git"
  },
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "build": "electron-builder --win nsis --publish never",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.local.packyapi.balance",
    "productName": "PackyAPI Balance",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://localhost/",
        "publishAutoUpdate": false
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "vitest": "^1.6.1"
  }
}
